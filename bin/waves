#!/bin/bash
#
# waves - Structured context protocol for AI agents
# https://github.com/exovian-developments/waves
#
# Usage:
#   waves init [claude|codex]  - Initialize waves in current directory
#   waves --version            - Show version
#   waves --help               - Show help
#

set -e

VERSION="2.1.2"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Determine where waves data files are installed
# Homebrew installs to: $(brew --prefix)/share/waves/
# For development/testing, check relative to script location
get_data_dir() {
    # Priority 1: Resolve the REAL location of the script (follow symlinks)
    # This handles the case where the binary is symlinked from /opt/homebrew/bin/
    # to a git repo — the repo always has the latest files.
    local real_script
    if command -v readlink &> /dev/null; then
        real_script="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "")"
    fi

    if [ -n "$real_script" ]; then
        local real_dir="$(cd "$(dirname "$real_script")" && pwd)"
        local real_parent="$(dirname "$real_dir")"
        if [ -d "$real_parent/schemas" ] && [ -d "$real_parent/.claude/commands" ]; then
            echo "$real_parent"
            return
        fi
    fi

    # Priority 2: Check relative to script path (without resolving symlinks)
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local parent_dir="$(dirname "$script_dir")"

    if [ -d "$parent_dir/schemas" ] && [ -d "$parent_dir/.claude/commands" ]; then
        echo "$parent_dir"
        return
    fi

    # Priority 3: Homebrew share directory (static copy from brew install)
    local brew_prefix
    if command -v brew &> /dev/null; then
        brew_prefix="$(brew --prefix 2>/dev/null)"
        if [ -d "$brew_prefix/share/waves" ]; then
            echo "$brew_prefix/share/waves"
            return
        fi
    fi

    # Last resort: current directory
    if [ -d "./schemas" ] && [ -d "./.claude/commands" ]; then
        echo "."
        return
    fi

    echo ""
}

show_banner() {
    echo ""
    local C1='\033[38;5;25m'
    local C2='\033[38;5;33m'
    local C3='\033[38;5;75m'
    echo -e "${C1}███${NC} ${C2}███${NC} ${C3}███${NC}  ${BOLD}${CYAN}█ █ █ ▄▀█ █ █ █▀▀ █▀${NC} ™ ${C3}███${NC} ${C2}███${NC} ${C1}███${NC}"
    echo -e "${C1}███${NC} ${C2}███${NC} ${C3}███${NC}  ${BOLD}${CYAN}▀▄▀▄▀ █▀█ ▀▄▀ ██▄ ▄█${NC}   ${C3}███${NC} ${C2}███${NC} ${C1}███${NC}"
    echo ""
    echo -e "${BOLD}« product development for the AI era »${NC}"
    echo -e "  Claude · Codex · Gemini CLI"
    echo ""
}

show_help() {
    show_banner
    echo -e "${BOLD}USAGE${NC}"
    echo "    waves <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo "    init [agent]    Initialize waves in current directory"
    echo "                    Supported agents: claude, codex (coming soon)"
    echo "    upgrade         Upgrade waves globally (Homebrew or git) and update"
    echo "                    the current project if inside one"
    echo ""
    echo -e "${BOLD}OPTIONS${NC}"
    echo "    --version, -v   Show version"
    echo "    --help, -h      Show this help"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "    waves init           # Interactive agent selection"
    echo "    waves init claude    # Initialize for Claude Code"
    echo "    waves upgrade        # Upgrade global + update current project"
    echo ""
    echo -e "${BOLD}AFTER INITIALIZATION${NC}"
    echo "    1. Start your AI agent (claude or codex)"
    echo "    2. Run: /waves:project-init"
    echo ""
    echo -e "Documentation: ${BLUE}https://github.com/exovian-developments/waves${NC}"
}

show_version() {
    echo "waves version $VERSION"
}

# Check if directory already has waves
check_existing() {
    local agent="$1"
    local has_ai_files=false
    local has_agent_commands=false

    if [ -d "ai_files" ]; then
        has_ai_files=true
    fi

    # Check for agent-specific commands
    case "$agent" in
        claude)
            [ -d ".claude/commands" ] && has_agent_commands=true
            ;;
        codex)
            [ -d ".codex/commands" ] && has_agent_commands=true
            ;;
    esac

    if $has_ai_files || $has_agent_commands; then
        echo -e "${YELLOW}Existing waves installation detected${NC}"
        echo ""

        if $has_ai_files; then
            echo -e "  ${CYAN}ai_files/${NC} exists"
            # Show what user files exist (won't be touched)
            # Preferences and config
            [ -f "ai_files/user_pref.json" ] && echo -e "    └─ user_pref.json ${GREEN}(will preserve)${NC}"
            # Blueprints (product, company, or legacy name)
            for bp in ai_files/blueprint.json ai_files/product_blueprint.json ai_files/company_blueprint.json; do
                [ -f "$bp" ] && echo -e "    └─ $(basename "$bp") ${GREEN}(will preserve)${NC}"
            done
            # Feasibility and foundation
            [ -f "ai_files/feasibility.json" ] && echo -e "    └─ feasibility.json ${GREEN}(will preserve)${NC}"
            [ -f "ai_files/foundation.json" ] && echo -e "    └─ foundation.json ${GREEN}(will preserve)${NC}"
            # Manifests (any type)
            for mf in ai_files/*manifest*.json; do
                [ -f "$mf" ] && echo -e "    └─ $(basename "$mf") ${GREEN}(will preserve)${NC}"
            done
            # Rules and standards
            for rf in ai_files/*rules*.json ai_files/*standards*.json; do
                [ -f "$rf" ] && echo -e "    └─ $(basename "$rf") ${GREEN}(will preserve)${NC}"
            done
            # Architecture map
            [ -f "ai_files/architecture_map.json" ] && echo -e "    └─ architecture_map.json ${GREEN}(will preserve)${NC}"
            # Waves directory
            [ -d "ai_files/waves" ] && echo -e "    └─ waves/ ${GREEN}(will preserve)${NC}"
        fi

        if $has_agent_commands; then
            echo -e "  ${CYAN}.${agent}/commands/${NC} exists"
        fi

        echo ""
        echo "Options:"
        echo -e "  1) ${GREEN}Update${NC} - Update schemas and commands only (preserves your data)"
        echo -e "  2) Cancel"
        echo ""
        read -p "Choose [1-2]: " choice
        case $choice in
            1)
                echo ""
                echo -e "${GREEN}Updating waves...${NC}"
                return 0
                ;;
            *)
                echo ""
                echo "Cancelled. No changes made."
                exit 0
                ;;
        esac
    fi
    return 0
}

# Select agent interactively
select_agent() {
    # Check which agents are already installed
    local claude_installed=false
    local codex_installed=false

    [ -d ".claude/commands" ] && claude_installed=true
    [ -d ".codex/commands" ] && codex_installed=true

    echo -e "${BOLD}Which AI agent do you want to set up?${NC}" >&2
    echo "" >&2

    # Show Claude option
    if $claude_installed; then
        echo -e "  1) Claude Code ${GREEN}(installed - will update)${NC}" >&2
    else
        echo "  1) Claude Code" >&2
    fi

    # Show Codex option
    if $codex_installed; then
        echo -e "  2) Codex ${GREEN}(installed - will update)${NC}" >&2
    else
        echo "  2) Codex (coming soon)" >&2
    fi

    # Show option to install both if one is already installed
    if $claude_installed || $codex_installed; then
        echo "" >&2
        echo -e "  ${CYAN}Tip: You can install multiple agents in the same project${NC}" >&2
    fi

    echo "" >&2
    read -p "Choose [1-2]: " choice
    case $choice in
        1)
            echo "claude"
            ;;
        2)
            echo "codex"
            ;;
        *)
            echo "" >&2
            echo -e "${RED}Invalid choice${NC}" >&2
            exit 1
            ;;
    esac
}

# Initialize for Claude Code
init_claude() {
    local data_dir="$1"

    echo -e "${BLUE}Initializing for Claude Code...${NC}"
    echo ""

    # Create directory structure
    echo -e "  ${GREEN}Creating${NC} ai_files/schemas/"
    mkdir -p ai_files/schemas

    echo -e "  ${GREEN}Creating${NC} ai_files/waves/"
    mkdir -p ai_files/waves

    echo -e "  ${GREEN}Creating${NC} .claude/commands/"
    mkdir -p .claude/commands

    # Copy schemas
    echo ""
    echo -e "${BLUE}Copying schemas...${NC}"
    local schema_count=0
    for schema in "$data_dir/schemas/"*.json; do
        if [ -f "$schema" ]; then
            local filename=$(basename "$schema")
            cp "$schema" "ai_files/schemas/$filename"
            echo -e "  ${GREEN}+${NC} $filename"
            schema_count=$((schema_count + 1))
        fi
    done
    echo -e "  ${GREEN}$schema_count schemas copied${NC}"

    # Copy commands
    echo ""
    echo -e "${BLUE}Copying slash commands...${NC}"
    local cmd_count=0
    for cmd in "$data_dir/.claude/commands/"*.md; do
        if [ -f "$cmd" ]; then
            local filename=$(basename "$cmd")
            cp "$cmd" ".claude/commands/$filename"
            echo -e "  ${GREEN}+${NC} $filename"
            cmd_count=$((cmd_count + 1))
        fi
    done
    echo -e "  ${GREEN}$cmd_count commands copied${NC}"

    # Copy hooks (Waves 2.0)
    if [ -d "$data_dir/.claude/hooks" ]; then
        echo ""
        echo -e "${BLUE}Copying hooks (Waves 2.0)...${NC}"
        mkdir -p .claude/hooks
        local hook_count=0
        for hook in "$data_dir/.claude/hooks/"*.sh; do
            if [ -f "$hook" ]; then
                local filename=$(basename "$hook")
                cp "$hook" ".claude/hooks/$filename"
                chmod +x ".claude/hooks/$filename"
                echo -e "  ${GREEN}+${NC} $filename"
                hook_count=$((hook_count + 1))
            fi
        done
        echo -e "  ${GREEN}$hook_count hooks installed${NC}"
    fi

    # Copy hooks settings (Waves 2.0)
    if [ -f "$data_dir/.claude/settings.json" ]; then
        if [ ! -f ".claude/settings.json" ]; then
            cp "$data_dir/.claude/settings.json" ".claude/settings.json"
            echo -e "  ${GREEN}+${NC} settings.json (hooks configuration)"
        elif grep -q '"matcher": ""' ".claude/settings.json" 2>/dev/null; then
            cp "$data_dir/.claude/settings.json" ".claude/settings.json"
            echo -e "  ${GREEN}+${NC} settings.json updated (fixed SessionStart hook config)"
        else
            echo -e "  ${YELLOW}!${NC} .claude/settings.json already exists — skipping (check manually for hook config)"
        fi
    fi

    # Update .gitignore
    if [ -f ".gitignore" ]; then
        if ! grep -q "ai_files/waves/" .gitignore 2>/dev/null; then
            echo "" >> .gitignore
            echo "# Waves delivery cycles (logbooks, resolutions — usually not committed)" >> .gitignore
            echo "ai_files/waves/" >> .gitignore
            echo ""
            echo -e "${BLUE}Updated .gitignore${NC}"
        fi
    fi

    # Write local version marker
    echo "$VERSION" > ".claude/waves-version"

    return 0
}

# Initialize for Codex (placeholder)
init_codex() {
    echo ""
    echo -e "${YELLOW}Codex support coming soon!${NC}"
    echo ""
    echo "For now, you can use the manual installation:"
    echo "  1. Copy schemas to ai_files/schemas/"
    echo "  2. Configure your Codex agent file"
    echo ""
    echo "Documentation: https://github.com/exovian-developments/waves"
    exit 0
}

# Main init command
cmd_init() {
    local agent="$1"

    show_banner

    # Get data directory
    local data_dir
    data_dir="$(get_data_dir)"

    if [ -z "$data_dir" ]; then
        echo -e "${RED}Error: Could not find waves data files${NC}"
        echo ""
        echo "Expected locations:"
        echo "  - \$(brew --prefix)/share/waves/"
        echo "  - Relative to script: ../schemas/ and ../.claude/commands/"
        echo ""
        echo "Please reinstall waves:"
        echo "  brew reinstall waves"
        exit 1
    fi

    # Check if schemas exist
    if [ ! -d "$data_dir/schemas" ]; then
        echo -e "${RED}Error: Schemas directory not found at $data_dir/schemas${NC}"
        exit 1
    fi

    # Select agent if not provided
    if [ -z "$agent" ]; then
        agent=$(select_agent)
        echo ""
    fi

    # Normalize agent name
    agent=$(echo "$agent" | tr '[:upper:]' '[:lower:]')

    # Validate agent
    case "$agent" in
        claude|codex)
            ;;
        *)
            echo -e "${RED}Error: Unknown agent '$agent'${NC}"
            echo "Supported agents: claude, codex"
            exit 1
            ;;
    esac

    # Check existing installation (now with agent context)
    check_existing "$agent"

    # Run agent-specific initialization
    case "$agent" in
        claude)
            init_claude "$data_dir"
            ;;
        codex)
            init_codex "$data_dir"
            ;;
    esac

    # Dynamic success message
    echo ""
    echo -e "${GREEN}${BOLD}Setup complete!${NC}"
    echo ""
    echo -e "  ${CYAN}ai_files/${NC}"
    echo -e "  ├── ${CYAN}schemas/${NC}      <- JSON schemas (updated)"
    echo -e "  └── ${CYAN}waves/${NC}        <- Delivery cycles (roadmaps, logbooks, resolutions)"
    echo ""

    # Show installed agents
    local agents_installed=""
    [ -d ".claude/commands" ] && agents_installed="${agents_installed} Claude"
    [ -d ".codex/commands" ] && agents_installed="${agents_installed} Codex"
    echo -e "  Agents configured:${CYAN}${agents_installed}${NC}"
    echo ""

    # Agent-specific next steps
    echo -e "${BOLD}Next steps:${NC}"
    echo ""
    case "$agent" in
        claude)
            echo -e "  1. Start Claude Code:"
            echo -e "     ${CYAN}claude${NC}"
            echo ""
            echo -e "  2. Initialize your preferences:"
            echo -e "     ${CYAN}/waves:project-init${NC}"
            ;;
        codex)
            echo -e "  1. Start Codex:"
            echo -e "     ${CYAN}codex${NC}"
            echo ""
            echo -e "  2. Tell your agent to read ai_files/user_pref_schema.json"
            ;;
    esac
    echo ""
    echo -e "  3. Create your project manifest:"
    echo -e "     ${CYAN}/waves:manifest-create${NC}"
    echo ""
    echo -e "${BLUE}Documentation:${NC} https://github.com/exovian-developments/waves"
    echo ""
}

# Upgrade command - updates global installation + local project
cmd_upgrade() {
    local skip_brew=false
    [ "${1:-}" = "--skip-brew" ] && skip_brew=true

    $skip_brew || show_banner

    local old_version="$VERSION"
    local upgraded=false

    # Step 1: Upgrade global installation
    if ! $skip_brew && command -v brew &> /dev/null; then
        local brew_prefix
        brew_prefix="$(brew --prefix 2>/dev/null)"

        # Check if waves is installed via Homebrew
        if brew list waves &> /dev/null; then
            echo -e "${BLUE}Checking for updates via Homebrew...${NC}"
            brew update 2>/dev/null

            # Get the version available in the tap
            local tap_version
            tap_version=$(brew info waves 2>/dev/null | head -1 | awk '{print $NF}' | sed 's/^v//')

            if [ -n "$tap_version" ] && [ "$tap_version" != "$old_version" ]; then
                echo -e "  ${YELLOW}New version available: v${tap_version}${NC}"
                brew reinstall waves 2>/dev/null
                # Re-read version from upgraded binary
                local new_bin="$brew_prefix/bin/waves"
                if [ -f "$new_bin" ]; then
                    local new_version
                    new_version=$(grep '^VERSION=' "$new_bin" 2>/dev/null | head -1 | cut -d'"' -f2)
                    if [ -n "$new_version" ] && [ "$new_version" != "$old_version" ]; then
                        echo -e "  ${GREEN}✓${NC} Upgraded ${YELLOW}v${old_version}${NC} → ${GREEN}v${new_version}${NC}"
                        # Re-exec with the new binary so new logic takes effect
                        echo ""
                        exec "$new_bin" upgrade --skip-brew
                    fi
                fi
            else
                echo -e "  ${GREEN}✓${NC} Already on latest version (v${VERSION})"
            fi
        else
            echo -e "${YELLOW}waves is not installed via Homebrew${NC}"
            echo -e "  Checking git source..."
        fi
    fi

    # Step 2: If installed via git (dev mode), pull latest
    local data_dir
    data_dir="$(get_data_dir)"

    if [ -n "$data_dir" ] && [ -d "$data_dir/.git" ] && ! $upgraded; then
        echo -e "${BLUE}Pulling latest from git...${NC}"
        local pull_output
        if pull_output=$(cd "$data_dir" && git pull origin main 2>&1); then
            if echo "$pull_output" | grep -q "Already up to date"; then
                echo -e "  ${GREEN}✓${NC} Already up to date"
            else
                local new_version
                new_version=$(grep '^VERSION=' "$data_dir/bin/waves" 2>/dev/null | head -1 | cut -d'"' -f2)
                if [ -n "$new_version" ] && [ "$new_version" != "$old_version" ]; then
                    echo -e "  ${GREEN}✓${NC} Updated ${YELLOW}v${old_version}${NC} → ${GREEN}v${new_version}${NC}"
                    VERSION="$new_version"
                    upgraded=true
                else
                    echo -e "  ${GREEN}✓${NC} Source updated"
                fi
            fi
        else
            echo -e "  ${YELLOW}⚠${NC} Could not pull from remote"
            echo -e "    ${CYAN}$(echo "$pull_output" | head -2)${NC}"
        fi
    fi

    echo ""

    # Step 3: If we're inside a project, update local files too
    local has_claude=false
    local has_ai_files=false
    [ -d ".claude/commands" ] && has_claude=true
    [ -d "ai_files" ] && has_ai_files=true

    if $has_claude || $has_ai_files; then
        # Read local project version
        local local_version="unknown"
        if [ -f ".claude/waves-version" ]; then
            local_version=$(cat ".claude/waves-version" 2>/dev/null)
        fi

        if [ "$local_version" = "$VERSION" ]; then
            echo -e "${BLUE}Updating current project...${NC} (already at v${VERSION})"
        elif [ "$local_version" = "unknown" ]; then
            echo -e "${BLUE}Updating current project...${NC} (pre-2.1.2 → v${VERSION})"
        else
            echo -e "${BLUE}Updating current project...${NC} (v${local_version} → v${VERSION})"
        fi

        # Re-resolve data_dir in case it changed after upgrade
        data_dir="$(get_data_dir)"

        if [ -z "$data_dir" ]; then
            echo -e "  ${RED}Could not find waves data files after upgrade${NC}"
            return 1
        fi

        # Update schemas
        if [ -d "ai_files/schemas" ]; then
            local schema_count=0
            for schema in "$data_dir/schemas/"*.json; do
                if [ -f "$schema" ]; then
                    cp "$schema" "ai_files/schemas/$(basename "$schema")"
                    schema_count=$((schema_count + 1))
                fi
            done
            echo -e "  ${GREEN}✓${NC} $schema_count schemas updated"
        fi

        # Update Claude commands
        if $has_claude; then
            # Remove old ai-behavior commands if any remain
            local migrated=0
            for old_cmd in .claude/commands/ai-behavior:*.md; do
                if [ -f "$old_cmd" ]; then
                    rm "$old_cmd"
                    migrated=$((migrated + 1))
                fi
            done
            [ $migrated -gt 0 ] && echo -e "  ${GREEN}✓${NC} Removed $migrated legacy ai-behavior commands"

            # Copy latest waves commands
            local cmd_count=0
            for cmd in "$data_dir/.claude/commands/"waves:*.md; do
                if [ -f "$cmd" ]; then
                    cp "$cmd" ".claude/commands/$(basename "$cmd")"
                    cmd_count=$((cmd_count + 1))
                fi
            done
            echo -e "  ${GREEN}✓${NC} $cmd_count waves commands updated"

            # Update hooks (Waves 2.0)
            if [ -d "$data_dir/.claude/hooks" ]; then
                mkdir -p .claude/hooks
                local hook_count=0
                for hook in "$data_dir/.claude/hooks/"*.sh; do
                    if [ -f "$hook" ]; then
                        cp "$hook" ".claude/hooks/$(basename "$hook")"
                        chmod +x ".claude/hooks/$(basename "$hook")"
                        hook_count=$((hook_count + 1))
                    fi
                done
                echo -e "  ${GREEN}✓${NC} $hook_count hooks updated"
            fi

            # Update settings.json (always overwrite — framework infrastructure, not user config)
            if [ -f "$data_dir/.claude/settings.json" ]; then
                cp "$data_dir/.claude/settings.json" ".claude/settings.json"
                echo -e "  ${GREEN}✓${NC} settings.json updated (hooks configuration)"
            fi
        fi

        # Show preserved artifacts
        echo ""
        echo -e "${GREEN}Preserved (untouched):${NC}"
        [ -f "ai_files/user_pref.json" ] && echo -e "  ${CYAN}✓${NC} user_pref.json"
        # Blueprints
        for bp in ai_files/blueprint.json ai_files/product_blueprint.json ai_files/company_blueprint.json; do
            [ -f "$bp" ] && echo -e "  ${CYAN}✓${NC} $(basename "$bp")"
        done
        # Feasibility and foundation
        [ -f "ai_files/feasibility.json" ] && echo -e "  ${CYAN}✓${NC} feasibility.json"
        [ -f "ai_files/foundation.json" ] && echo -e "  ${CYAN}✓${NC} foundation.json"
        # Manifests (any type)
        for mf in ai_files/*manifest*.json; do
            [ -f "$mf" ] && echo -e "  ${CYAN}✓${NC} $(basename "$mf")"
        done
        # Rules and standards
        for rf in ai_files/*rules*.json ai_files/*standards*.json; do
            [ -f "$rf" ] && echo -e "  ${CYAN}✓${NC} $(basename "$rf")"
        done
        # Architecture map
        [ -f "ai_files/architecture_map.json" ] && echo -e "  ${CYAN}✓${NC} architecture_map.json"
        # Waves and CLAUDE.md
        [ -d "ai_files/waves" ] && echo -e "  ${CYAN}✓${NC} waves/"
        [ -f "CLAUDE.md" ] && echo -e "  ${CYAN}✓${NC} CLAUDE.md"
    else
        echo -e "${CYAN}Not inside a waves project — only global installation was upgraded.${NC}"
        echo -e "To update a project, ${CYAN}cd${NC} into it and run ${CYAN}waves upgrade${NC} again."
    fi

    # Write local version marker
    if $has_claude || $has_ai_files; then
        mkdir -p .claude 2>/dev/null
        echo "$VERSION" > ".claude/waves-version"
    fi

    echo ""
    echo -e "${GREEN}${BOLD}Upgrade complete!${NC} (v${VERSION})"

    # Post-upgrade instruction
    if $has_claude || $has_ai_files; then
        echo ""
        echo -e "${YELLOW}${BOLD}Important:${NC} To finish the upgrade, open Claude Code in this project and run:"
        echo ""
        echo -e "  ${CYAN}/waves:upgrade${NC}"
        echo ""
        echo -e "This updates the Agent Operating Protocol in CLAUDE.md with the latest"
        echo -e "decision classification, metacognition, and enforcement rules."
        echo -e "Without this step, your CLAUDE.md may be inconsistent with the installed hooks."
    fi
}

# Main entry point
main() {
    case "${1:-}" in
        init)
            cmd_init "$2"
            ;;
        update|upgrade)
            cmd_upgrade "$2"
            ;;
        --version|-v)
            show_version
            ;;
        --help|-h|"")
            show_help
            ;;
        *)
            echo -e "${RED}Error: Unknown command '$1'${NC}"
            echo ""
            echo "Run 'waves --help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
