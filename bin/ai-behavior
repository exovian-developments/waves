#!/bin/bash
#
# ai-behavior - Structured context protocol for AI agents
# https://github.com/exovian-developments/ai-behavior
#
# Usage:
#   ai-behavior init [claude|codex]  - Initialize ai-behavior in current directory
#   ai-behavior --version            - Show version
#   ai-behavior --help               - Show help
#

set -e

VERSION="0.3.0"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Determine where ai-behavior data files are installed
# Homebrew installs to: $(brew --prefix)/share/ai-behavior/
# For development/testing, check relative to script location
get_data_dir() {
    # First, check if running from Homebrew installation
    local brew_prefix
    if command -v brew &> /dev/null; then
        brew_prefix="$(brew --prefix 2>/dev/null)"
        if [ -d "$brew_prefix/share/ai-behavior" ]; then
            echo "$brew_prefix/share/ai-behavior"
            return
        fi
    fi

    # Fallback: check relative to script (for development)
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local parent_dir="$(dirname "$script_dir")"

    # Check if schemas exist in parent directory (development mode)
    if [ -d "$parent_dir/schemas" ] && [ -d "$parent_dir/.claude/commands" ]; then
        echo "$parent_dir"
        return
    fi

    # Last resort: check current directory structure
    if [ -d "./schemas" ] && [ -d "./.claude/commands" ]; then
        echo "."
        return
    fi

    echo ""
}

show_banner() {
    echo ""
    echo -e "${CYAN}▄▀█ █   █▄▄ █▀▀ █ █ ▄▀█ █ █ █ █▀█ █▀█${NC}"
    echo -e "${CYAN}█▀█ █   █▄█ ██▄ █▀█ █▀█ ▀▄▀ █ █▄█ █▀▄${NC}"
    echo ""
    echo -e "${BOLD}« structured context for AI agents »${NC}"
    echo -e "  Claude · Codex · Gemini CLI"
    echo ""
}

show_help() {
    show_banner
    echo -e "${BOLD}USAGE${NC}"
    echo "    ai-behavior <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo "    init [agent]    Initialize ai-behavior in current directory"
    echo "                    Supported agents: claude, codex (coming soon)"
    echo "    update          Update schemas and commands in current directory"
    echo "                    Auto-detects installed agent(s), preserves user data"
    echo ""
    echo -e "${BOLD}OPTIONS${NC}"
    echo "    --version, -v   Show version"
    echo "    --help, -h      Show this help"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "    ai-behavior init           # Interactive agent selection"
    echo "    ai-behavior init claude    # Initialize for Claude Code"
    echo "    ai-behavior update         # Update current project in-place"
    echo ""
    echo -e "${BOLD}AFTER INITIALIZATION${NC}"
    echo "    1. Start your AI agent (claude or codex)"
    echo "    2. Run: /ai-behavior:project-init"
    echo ""
    echo -e "Documentation: ${BLUE}https://github.com/exovian-developments/ai-behavior${NC}"
}

show_version() {
    echo "ai-behavior version $VERSION"
}

# Check if directory already has ai-behavior
check_existing() {
    local agent="$1"
    local has_ai_files=false
    local has_agent_commands=false

    if [ -d "ai_files" ]; then
        has_ai_files=true
    fi

    # Check for agent-specific commands
    case "$agent" in
        claude)
            [ -d ".claude/commands" ] && has_agent_commands=true
            ;;
        codex)
            [ -d ".codex/commands" ] && has_agent_commands=true
            ;;
    esac

    if $has_ai_files || $has_agent_commands; then
        echo -e "${YELLOW}Existing ai-behavior installation detected${NC}"
        echo ""

        if $has_ai_files; then
            echo -e "  ${CYAN}ai_files/${NC} exists"
            # Show what user files exist (won't be touched)
            [ -f "ai_files/user_pref.json" ] && echo -e "    └─ user_pref.json ${GREEN}(will preserve)${NC}"
            [ -f "ai_files/project_manifest.json" ] && echo -e "    └─ project_manifest.json ${GREEN}(will preserve)${NC}"
            [ -f "ai_files/project_rules.json" ] && echo -e "    └─ project_rules.json ${GREEN}(will preserve)${NC}"
            [ -d "ai_files/logbooks" ] && echo -e "    └─ logbooks/ ${GREEN}(will preserve)${NC}"
        fi

        if $has_agent_commands; then
            echo -e "  ${CYAN}.${agent}/commands/${NC} exists"
        fi

        echo ""
        echo "Options:"
        echo -e "  1) ${GREEN}Update${NC} - Update schemas and commands only (preserves your data)"
        echo -e "  2) Cancel"
        echo ""
        read -p "Choose [1-2]: " choice
        case $choice in
            1)
                echo ""
                echo -e "${GREEN}Updating ai-behavior...${NC}"
                return 0
                ;;
            *)
                echo ""
                echo "Cancelled. No changes made."
                exit 0
                ;;
        esac
    fi
    return 0
}

# Select agent interactively
select_agent() {
    # Check which agents are already installed
    local claude_installed=false
    local codex_installed=false

    [ -d ".claude/commands" ] && claude_installed=true
    [ -d ".codex/commands" ] && codex_installed=true

    echo -e "${BOLD}Which AI agent do you want to set up?${NC}" >&2
    echo "" >&2

    # Show Claude option
    if $claude_installed; then
        echo -e "  1) Claude Code ${GREEN}(installed - will update)${NC}" >&2
    else
        echo "  1) Claude Code" >&2
    fi

    # Show Codex option
    if $codex_installed; then
        echo -e "  2) Codex ${GREEN}(installed - will update)${NC}" >&2
    else
        echo "  2) Codex (coming soon)" >&2
    fi

    # Show option to install both if one is already installed
    if $claude_installed || $codex_installed; then
        echo "" >&2
        echo -e "  ${CYAN}Tip: You can install multiple agents in the same project${NC}" >&2
    fi

    echo "" >&2
    read -p "Choose [1-2]: " choice
    case $choice in
        1)
            echo "claude"
            ;;
        2)
            echo "codex"
            ;;
        *)
            echo "" >&2
            echo -e "${RED}Invalid choice${NC}" >&2
            exit 1
            ;;
    esac
}

# Initialize for Claude Code
init_claude() {
    local data_dir="$1"

    echo -e "${BLUE}Initializing for Claude Code...${NC}"
    echo ""

    # Create directory structure
    echo -e "  ${GREEN}Creating${NC} ai_files/schemas/"
    mkdir -p ai_files/schemas

    echo -e "  ${GREEN}Creating${NC} ai_files/logbooks/"
    mkdir -p ai_files/logbooks

    echo -e "  ${GREEN}Creating${NC} .claude/commands/"
    mkdir -p .claude/commands

    # Copy schemas
    echo ""
    echo -e "${BLUE}Copying schemas...${NC}"
    local schema_count=0
    for schema in "$data_dir/schemas/"*.json; do
        if [ -f "$schema" ]; then
            local filename=$(basename "$schema")
            cp "$schema" "ai_files/schemas/$filename"
            echo -e "  ${GREEN}+${NC} $filename"
            schema_count=$((schema_count + 1))
        fi
    done
    echo -e "  ${GREEN}$schema_count schemas copied${NC}"

    # Copy commands
    echo ""
    echo -e "${BLUE}Copying slash commands...${NC}"
    local cmd_count=0
    for cmd in "$data_dir/.claude/commands/"*.md; do
        if [ -f "$cmd" ]; then
            local filename=$(basename "$cmd")
            cp "$cmd" ".claude/commands/$filename"
            echo -e "  ${GREEN}+${NC} $filename"
            cmd_count=$((cmd_count + 1))
        fi
    done
    echo -e "  ${GREEN}$cmd_count commands copied${NC}"

    # Update .gitignore
    if [ -f ".gitignore" ]; then
        if ! grep -q "ai_files/logbooks/" .gitignore 2>/dev/null; then
            echo "" >> .gitignore
            echo "# AI behavior logbooks (work in progress, usually not committed)" >> .gitignore
            echo "ai_files/logbooks/" >> .gitignore
            echo ""
            echo -e "${BLUE}Updated .gitignore${NC}"
        fi
    fi

    return 0
}

# Initialize for Codex (placeholder)
init_codex() {
    echo ""
    echo -e "${YELLOW}Codex support coming soon!${NC}"
    echo ""
    echo "For now, you can use the manual installation:"
    echo "  1. Copy schemas to ai_files/schemas/"
    echo "  2. Configure your Codex agent file"
    echo ""
    echo "Documentation: https://github.com/exovian-developments/ai-behavior"
    exit 0
}

# Main init command
cmd_init() {
    local agent="$1"

    show_banner

    # Get data directory
    local data_dir
    data_dir="$(get_data_dir)"

    if [ -z "$data_dir" ]; then
        echo -e "${RED}Error: Could not find ai-behavior data files${NC}"
        echo ""
        echo "Expected locations:"
        echo "  - \$(brew --prefix)/share/ai-behavior/"
        echo "  - Relative to script: ../schemas/ and ../.claude/commands/"
        echo ""
        echo "Please reinstall ai-behavior:"
        echo "  brew reinstall ai-behavior"
        exit 1
    fi

    # Check if schemas exist
    if [ ! -d "$data_dir/schemas" ]; then
        echo -e "${RED}Error: Schemas directory not found at $data_dir/schemas${NC}"
        exit 1
    fi

    # Select agent if not provided
    if [ -z "$agent" ]; then
        agent=$(select_agent)
        echo ""
    fi

    # Normalize agent name
    agent=$(echo "$agent" | tr '[:upper:]' '[:lower:]')

    # Validate agent
    case "$agent" in
        claude|codex)
            ;;
        *)
            echo -e "${RED}Error: Unknown agent '$agent'${NC}"
            echo "Supported agents: claude, codex"
            exit 1
            ;;
    esac

    # Check existing installation (now with agent context)
    check_existing "$agent"

    # Run agent-specific initialization
    case "$agent" in
        claude)
            init_claude "$data_dir"
            ;;
        codex)
            init_codex "$data_dir"
            ;;
    esac

    # Dynamic success message
    echo ""
    echo -e "${GREEN}${BOLD}Setup complete!${NC}"
    echo ""
    echo -e "  ${CYAN}ai_files/${NC}"
    echo -e "  ├── ${CYAN}schemas/${NC}      <- JSON schemas (updated)"
    echo -e "  └── ${CYAN}logbooks/${NC}     <- Your work logbooks (preserved)"
    echo ""

    # Show installed agents
    local agents_installed=""
    [ -d ".claude/commands" ] && agents_installed="${agents_installed} Claude"
    [ -d ".codex/commands" ] && agents_installed="${agents_installed} Codex"
    echo -e "  Agents configured:${CYAN}${agents_installed}${NC}"
    echo ""

    # Agent-specific next steps
    echo -e "${BOLD}Next steps:${NC}"
    echo ""
    case "$agent" in
        claude)
            echo -e "  1. Start Claude Code:"
            echo -e "     ${CYAN}claude${NC}"
            echo ""
            echo -e "  2. Initialize your preferences:"
            echo -e "     ${CYAN}/ai-behavior:project-init${NC}"
            ;;
        codex)
            echo -e "  1. Start Codex:"
            echo -e "     ${CYAN}codex${NC}"
            echo ""
            echo -e "  2. Tell your agent to read ai_files/user_pref_schema.json"
            ;;
    esac
    echo ""
    echo -e "  3. Create your project manifest:"
    echo -e "     ${CYAN}/ai-behavior:manifest-create${NC}"
    echo ""
    echo -e "${BLUE}Documentation:${NC} https://github.com/exovian-developments/ai-behavior"
    echo ""
}

# Update command - non-interactive, auto-detects agent
cmd_update() {
    local data_dir
    data_dir="$(get_data_dir)"

    if [ -z "$data_dir" ]; then
        echo -e "${RED}Error: Could not find ai-behavior data files${NC}"
        echo ""
        echo "Please reinstall ai-behavior:"
        echo "  brew reinstall ai-behavior"
        exit 1
    fi

    # Pull latest from remote if data_dir is a git repository
    if [ -d "$data_dir/.git" ]; then
        echo -e "${BLUE}Fetching latest ai-behavior from remote...${NC}"
        local pull_output
        if pull_output=$(cd "$data_dir" && git pull origin main 2>&1); then
            if echo "$pull_output" | grep -q "Already up to date"; then
                echo -e "  ${GREEN}✓${NC} Already up to date"
            else
                # Re-read version from the updated script
                local new_version
                new_version=$(grep '^VERSION=' "$data_dir/bin/ai-behavior" 2>/dev/null | head -1 | cut -d'"' -f2)
                if [ -n "$new_version" ] && [ "$new_version" != "$VERSION" ]; then
                    echo -e "  ${GREEN}✓${NC} Updated source ${YELLOW}v${VERSION}${NC} → ${GREEN}v${new_version}${NC}"
                    VERSION="$new_version"
                else
                    echo -e "  ${GREEN}✓${NC} Source updated"
                fi
            fi
        else
            echo -e "  ${YELLOW}⚠${NC} Could not pull from remote (continuing with local files)"
            echo -e "    ${CYAN}$pull_output${NC}" | head -3
        fi
        echo ""
    fi

    # Detect which agents are installed
    local has_claude=false
    local has_codex=false
    local has_ai_files=false

    [ -d ".claude/commands" ] && has_claude=true
    [ -d ".codex/commands" ] && has_codex=true
    [ -d "ai_files" ] && has_ai_files=true

    if ! $has_claude && ! $has_codex && ! $has_ai_files; then
        echo -e "${RED}Error: No ai-behavior installation detected in current directory${NC}"
        echo ""
        echo "Run ${CYAN}ai-behavior init${NC} first to set up your project."
        exit 1
    fi

    echo -e "${BLUE}Updating ai-behavior to v${VERSION}...${NC}"
    echo ""

    # Update schemas
    if $has_ai_files || $has_claude || $has_codex; then
        mkdir -p ai_files/schemas
        local schema_count=0
        for schema in "$data_dir/schemas/"*.json; do
            if [ -f "$schema" ]; then
                local filename=$(basename "$schema")
                cp "$schema" "ai_files/schemas/$filename"
                schema_count=$((schema_count + 1))
            fi
        done
        echo -e "  ${GREEN}✓${NC} $schema_count schemas updated"
    fi

    # Update Claude commands
    if $has_claude; then
        local cmd_count=0
        for cmd in "$data_dir/.claude/commands/"*.md; do
            if [ -f "$cmd" ]; then
                local filename=$(basename "$cmd")
                cp "$cmd" ".claude/commands/$filename"
                cmd_count=$((cmd_count + 1))
            fi
        done
        echo -e "  ${GREEN}✓${NC} $cmd_count Claude commands updated"
    fi

    # Update Codex commands (future)
    if $has_codex; then
        echo -e "  ${GREEN}✓${NC} Codex commands updated"
    fi

    # Show what was preserved
    echo ""
    echo -e "${GREEN}Preserved (untouched):${NC}"
    [ -f "ai_files/user_pref.json" ] && echo -e "  ${CYAN}✓${NC} user_pref.json"
    [ -f "ai_files/project_manifest.json" ] && echo -e "  ${CYAN}✓${NC} project_manifest.json"
    [ -f "ai_files/project_rules.json" ] && echo -e "  ${CYAN}✓${NC} project_rules.json"
    [ -d "ai_files/logbooks" ] && echo -e "  ${CYAN}✓${NC} logbooks/"
    [ -f "ai_files/product_blueprint.json" ] && echo -e "  ${CYAN}✓${NC} product_blueprint.json"
    [ -f "ai_files/product_foundation.json" ] && echo -e "  ${CYAN}✓${NC} product_foundation.json"
    for feas in ai_files/*_feasibility.json; do
        [ -f "$feas" ] && echo -e "  ${CYAN}✓${NC} $(basename "$feas")"
    done
    for road in ai_files/*_roadmap.json; do
        [ -f "$road" ] && echo -e "  ${CYAN}✓${NC} $(basename "$road")"
    done

    echo ""
    echo -e "${GREEN}${BOLD}Update complete!${NC} (v${VERSION})"
}

# Main entry point
main() {
    case "${1:-}" in
        init)
            cmd_init "$2"
            ;;
        update|upgrade)
            cmd_update
            ;;
        --version|-v)
            show_version
            ;;
        --help|-h|"")
            show_help
            ;;
        *)
            echo -e "${RED}Error: Unknown command '$1'${NC}"
            echo ""
            echo "Run 'ai-behavior --help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
